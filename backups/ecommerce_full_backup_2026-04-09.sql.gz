/*!50003 DROP FUNCTION IF EXISTS `fn_order_total_items` */;
/*!50003 SET @saved_cs_client      = @@character_set_client */;
/*!50003 SET character_set_client = utf8mb4 */;
DELIMITER $$
CREATE DEFINER=`root`@`localhost` FUNCTION `fn_order_total_items`(p_order_id INT) RETURNS INT DETERMINISTIC
BEGIN
  DECLARE v_total INT;
  SELECT IFNULL(SUM(quantity),0) INTO v_total FROM order_items WHERE order_id = p_order_id;
  RETURN v_total;
END$$
DELIMITER ;
