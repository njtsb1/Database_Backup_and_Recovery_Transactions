/*!50003 DROP TRIGGER IF EXISTS `trg_after_insert_order_item` */;
/*!50003 SET @saved_cs_client      = @@character_set_client */;
/*!50003 SET character_set_client = utf8mb4 */;
DELIMITER $$
CREATE DEFINER=`root`@`localhost` TRIGGER `trg_after_insert_order_item`
AFTER INSERT ON `order_items`
FOR EACH ROW
BEGIN
  UPDATE orders
    SET total_amount = (SELECT IFNULL(SUM(quantity * unit_price),0) FROM order_items WHERE order_id = NEW.order_id)
    WHERE id = NEW.order_id;
END$$
DELIMITER ;
